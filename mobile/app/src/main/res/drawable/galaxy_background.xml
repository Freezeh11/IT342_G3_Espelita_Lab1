<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Base very dark -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#03010a" />
        </shape>
    </item>
    <!-- Strong purple glow from top-left -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:startColor="#3a1475"
                android:endColor="#00000000"
                android:type="radial"
                android:gradientRadius="500dp"
                android:centerX="0.1"
                android:centerY="0.05" />
        </shape>
    </item>
    <!-- Mid purple spread -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:startColor="#200a4a"
                android:endColor="#00000000"
                android:type="radial"
                android:gradientRadius="650dp"
                android:centerX="0.25"
                android:centerY="0.2" />
        </shape>
    </item>
    <!-- Faint ambient towards center -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:startColor="#0a0530"
                android:endColor="#00000000"
                android:type="radial"
                android:gradientRadius="400dp"
                android:centerX="0.5"
                android:centerY="0.45" />
        </shape>
    </item>
</layer-list>
