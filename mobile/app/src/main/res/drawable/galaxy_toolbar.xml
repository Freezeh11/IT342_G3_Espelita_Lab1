<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Base dark toolbar -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#06021a" />
        </shape>
    </item>
    <!-- Purple glow from right fading to dark left -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:startColor="#3a1475"
                android:endColor="#00000000"
                android:type="radial"
                android:gradientRadius="280dp"
                android:centerX="1.0"
                android:centerY="0.5" />
        </shape>
    </item>
    <!-- Subtle bottom border -->
    <item android:top="-1dp" android:left="-1dp" android:right="-1dp">
        <shape android:shape="rectangle">
            <stroke
                android:width="1dp"
                android:color="#1a1040" />
            <solid android:color="#00000000" />
        </shape>
    </item>
</layer-list>
